#!/bin/bash

PROJECT="allsports-league"
DATE=$(date +"%Y-%m-%d_%H-%M-%S")
BACKUP_DIR="$HOME/ASL_Backups"

mkdir -p "$BACKUP_DIR"

zip -r "$BACKUP_DIR/${PROJECT}_$DATE.zip" . \
-x "node_modules/*" \
".next/*" \
".git/*" \
"coverage/*" \
"dist/*"

echo ""
echo "✅ Backup creado:"
echo "$BACKUP_DIR/${PROJECT}_$DATE.zip"
ø
